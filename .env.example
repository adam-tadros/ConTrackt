# Copy to .env and fill in. .env is git-ignored.

# --- AWS credentials (or use `aws configure` / an IAM role instead) -------
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# --- S3 -------------------------------------------------------------------
S3_BUCKET=contrackt-documents
S3_UPLOAD_PREFIX=uploads/
PRESIGN_EXPIRY=3600

# --- DynamoDB -------------------------------------------------------------
DDB_CONTRACTS_TABLE=contrackt_contracts
DDB_DOCUMENTS_TABLE=contrackt_documents

# --- Bedrock --------------------------------------------------------------
# Model must be enabled under Bedrock -> Model access in this region.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# --- App ------------------------------------------------------------------
MAX_UPLOAD_MB=20
ALERT_WINDOW_DAYS=30
SECRET_KEY=change-me
