{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadUploadedObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::contrackt-docs-221889532759/*"
    },
    {
      "Sid": "UpdateDocumentRecords",
      "Effect": "Allow",
      "Action": [
        "dynamodb:Scan",
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/contrackt_documents",
        "arn:aws:dynamodb:*:*:table/contrackt_documents/index/*"
      ]
    },
    {
      "Sid": "Bedrock",
      "Effect": "Allow",
      "Action": ["bedrock:InvokeModel", "bedrock:InvokeModelWithResponseStream"],
      "Resource": "*"
    },
    {
      "Sid": "Textract",
      "Effect": "Allow",
      "Action": ["textract:DetectDocumentText", "textract:AnalyzeDocument"],
      "Resource": "*"
    }
  ]
}
